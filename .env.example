# ─────────────────────────────────────────────────────────────
# wp-craft — .env.example
# Copy to .env and fill in values. Never commit .env.
# ─────────────────────────────────────────────────────────────

# ── WordPress ────────────────────────────────────────────────
WP_HOME=https://example.com
WP_SITEURL=https://example.com/wp

# ── Database ─────────────────────────────────────────────────
DB_NAME=wordpress
DB_USER=wordpress
DB_PASSWORD=
DB_HOST=127.0.0.1
DB_PREFIX=wp_

# ── Environment ──────────────────────────────────────────────
WP_ENV=development   # development | staging | production
WP_DEBUG=true
WP_DEBUG_LOG=true
WP_DEBUG_DISPLAY=false

# ── Security keys (generate at https://roots.io/salts) ───────
AUTH_KEY=
SECURE_AUTH_KEY=
LOGGED_IN_KEY=
NONCE_KEY=
AUTH_SALT=
SECURE_AUTH_SALT=
LOGGED_IN_SALT=
NONCE_SALT=

# ── Email (SMTP) ─────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@example.com
# Acorn v6 / Laravel 13: usa MAIL_SCHEME invece di MAIL_ENCRYPTION
# MAIL_SCHEME=tls

# ── Newsletter (ESP) ─────────────────────────────────────────
# Mailchimp
MAILCHIMP_API_KEY=
MAILCHIMP_LIST_ID=
# OR Klaviyo
KLAVIYO_PRIVATE_KEY=
KLAVIYO_LIST_ID=

# ── Google Analytics ─────────────────────────────────────────
GA_MEASUREMENT_ID=

# ── Acorn v6 — breaking changes (solo se stai aggiornando da v5) ──────────
# Acorn v6 (Laravel 13) ha cambiato i separatori nei prefissi cache/session.
# Se stai migrando un sito ESISTENTE, imposta questi valori per preservare
# sessioni attive e cache senza invalidarle.
# Per siti NUOVI, lascia queste righe commentate (userà i nuovi default).
#
# CACHE_PREFIX=laravel_cache_
# SESSION_COOKIE=laravel_session
# REDIS_PREFIX=laravel_database_

# ── Vite (only needed if overriding defaults) ─────────────────
# VITE_PORT=5173
