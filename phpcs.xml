<?xml version="1.0"?>
<ruleset name="sage-theme">
    <description>PHP_CodeSniffer ruleset for sage-theme (Roots Sage 11 / WordPress)</description>

    <!-- Files to check -->
    <file>app/</file>
    <file>woocommerce/</file>
    <file>functions.php</file>

    <!-- Ignore generated/vendor code -->
    <exclude-pattern>*/vendor/*</exclude-pattern>
    <exclude-pattern>*/node_modules/*</exclude-pattern>
    <exclude-pattern>*/public/*</exclude-pattern>

    <!-- WordPress Coding Standards -->
    <rule ref="WordPress">
        <!-- We use PSR-4 / Acorn namespaces, not WP file naming -->
        <exclude name="WordPress.Files.FileName"/>
        <!-- Blade closures use short closures (fn() =>) which WPCS flags -->
        <exclude name="Universal.Functions.DisallowShortClosures"/>
    </rule>

    <!-- Enforce WordPress security sniffs -->
    <rule ref="WordPress.Security"/>

    <!-- PHP 8.2 compatibility -->
    <rule ref="PHPCompatibilityWP"/>
    <config name="testVersion" value="8.2-"/>
    <config name="minimum_supported_wp_version" value="6.4"/>

    <!-- Allow short array syntax -->
    <rule ref="Generic.Arrays.DisallowLongArraySyntax"/>

    <!-- Enforce output escaping -->
    <rule ref="WordPress.Security.EscapeOutput">
        <properties>
            <property name="customAutoEscapedFunctions" type="array">
                <!-- Blade {!! !!} escaping via WordPress helpers is assumed -->
                <element value="esc_html"/>
                <element value="esc_attr"/>
                <element value="esc_url"/>
                <element value="wp_kses_post"/>
                <element value="absint"/>
            </property>
        </properties>
    </rule>

    <!-- Require prepared statements for all DB queries -->
    <rule ref="WordPress.DB.PreparedSQL"/>
    <rule ref="WordPress.DB.PreparedSQLPlaceholders"/>

    <!-- Nonce verification on any form/AJAX handler -->
    <rule ref="WordPress.Security.NonceVerification"/>
</ruleset>
