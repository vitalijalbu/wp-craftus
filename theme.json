{
  "__preprocessed__": "This file is used to build the theme.json file in the `public/build/assets` directory. The built artifact includes Tailwind's colors, fonts, and font sizes.",
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "settings": {
    "appearanceTools": true,
    "layout": {
      "contentSize": "1200px",
      "wideSize": "1440px"
    },
    "background": {
      "backgroundImage": true
    },
    "color": {
      "custom": true,
      "customDuotone": false,
      "customGradient": true,
      "defaultDuotone": false,
      "defaultGradients": false,
      "defaultPalette": false,
      "duotone": [],
      "palette": [
        { "slug": "black",        "color": "#111111", "name": "Nero" },
        { "slug": "dark",         "color": "#1a1a2e", "name": "Dark Navy" },
        { "slug": "dark-900",     "color": "#1e293b", "name": "Dark 900" },
        { "slug": "dark-50",      "color": "#f0f6ff", "name": "Blu 50" },
        { "slug": "primary",      "color": "#3E80C4", "name": "Blu Primary" },
        { "slug": "primary-dark", "color": "#2d69a8", "name": "Blu Scuro" },
        { "slug": "primary-light","color": "#bfdbfe", "name": "Blu Chiaro" },
        { "slug": "white",        "color": "#ffffff", "name": "Bianco" },
        { "slug": "off-white",    "color": "#f8fafc", "name": "Off White" },
        { "slug": "gray-100",     "color": "#f1f5f9", "name": "Grigio 100" },
        { "slug": "gray-200",     "color": "#e2e8f0", "name": "Grigio 200" },
        { "slug": "gray-500",     "color": "#64748b", "name": "Grigio 500" },
        { "slug": "gray-600",     "color": "#475569", "name": "Grigio 600" }
      ],
      "gradients": [
        {
          "slug": "primary-to-dark",
          "gradient": "linear-gradient(135deg, #3E80C4 0%, #1a1a2e 100%)",
          "name": "Blu a Scuro"
        },
        {
          "slug": "dark-overlay",
          "gradient": "linear-gradient(180deg, rgba(26,26,46,0.5) 0%, rgba(26,26,46,0.7) 100%)",
          "name": "Overlay Scuro"
        }
      ]
    },
    "custom": {
      "spacing": {},
      "typography": {
        "font-size": {},
        "line-height": {}
      }
    },
    "spacing": {
      "padding": true,
      "units": ["px", "%", "em", "rem", "vw", "vh"]
    },
    "typography": {
      "defaultFontSizes": false,
      "customFontSize": true,
      "fluid": true,
      "fontFamilies": [
        {
          "fontFamily": "'Poppins', system-ui, sans-serif",
          "slug": "sans",
          "name": "Poppins"
        },
        {
          "name": "Serif",
          "slug": "serif",
          "fontFamily": "'Cormorant Garamond', Georgia, serif"
        }
      ],
      "fontSizes": [
        { "slug": "sm",   "size": "0.875rem",                    "name": "Small" },
        { "slug": "base", "size": "1rem",                        "name": "Base" },
        { "slug": "lg",   "size": "1.125rem",                    "name": "Large" },
        { "slug": "xl",   "size": "1.25rem",                     "name": "XL" },
        { "slug": "2xl",  "size": "1.5rem",                      "name": "2XL" },
        { "slug": "3xl",  "size": "1.875rem",                    "name": "3XL" },
        { "slug": "4xl",  "size": "2.25rem",                     "name": "4XL" },
        { "slug": "5xl",  "size": "3rem",                        "name": "5XL" },
        { "slug": "hero", "size": "clamp(2.5rem, 5vw, 4.5rem)",  "name": "Hero" }
      ]
    },
    "border": {
      "color": true,
      "radius": true,
      "style": true,
      "width": true
    }
  },
  "styles": {
    "color": {
      "background": "#ffffff",
      "text": "#111111"
    },
    "typography": {
      "fontFamily": "var(--wp--preset--font-family--sans)",
      "fontSize": "var(--wp--preset--font-size--base)",
      "lineHeight": "1.65"
    },
    "elements": {
      "h1": { "typography": { "fontFamily": "var(--wp--preset--font-family--sans)", "fontWeight": "700", "lineHeight": "1.1" } },
      "h2": { "typography": { "fontFamily": "var(--wp--preset--font-family--sans)", "fontWeight": "700", "lineHeight": "1.2" } },
      "h3": { "typography": { "fontFamily": "var(--wp--preset--font-family--sans)", "fontWeight": "600", "lineHeight": "1.3" } },
      "h4": { "typography": { "fontFamily": "var(--wp--preset--font-family--sans)", "fontWeight": "600" } },
      "link": {
        "color": { "text": "#111111" },
        "typography": { "textDecoration": "none" },
        ":hover": { "color": { "text": "#3E80C4" } }
      },
      "button": {
        "color": { "background": "#3E80C4", "text": "#ffffff" },
        "typography": { "fontFamily": "var(--wp--preset--font-family--sans)", "fontWeight": "600", "textDecoration": "none" },
        "border": { "radius": "4px" },
        "spacing": { "padding": { "top": "0.75rem", "bottom": "0.75rem", "left": "1.5rem", "right": "1.5rem" } }
      }
    }
  }
}
