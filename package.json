{
  "name": "sage",
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "translate": "npm run translate:pot && npm run translate:update",
    "translate:pot": "wp i18n make-pot . ./resources/lang/sage.pot --include=\"theme.json,patterns,app,resources\"",
    "translate:update": "for file in ./resources/lang/*.po; do wp i18n update-po ./resources/lang/sage.pot $file; done",
    "translate:compile": "npm run translate:mo && npm run translate:js",
    "translate:js": "wp i18n make-json ./resources/lang --pretty-print",
    "translate:mo": "wp i18n make-mo ./resources/lang ./resources/lang",
    "lint": "biome lint resources/js/",
    "lint:fix": "biome lint --write resources/js/",
    "format": "biome format resources/js/ templates/ parts/",
    "format:fix": "biome format --write resources/js/ templates/ parts/",
    "check": "biome check resources/js/ templates/ parts/",
    "check:fix": "biome check --write resources/js/ templates/ parts/",
    "fix-all": "biome check --write --unsafe resources/js/ templates/ parts/",
    "ci": "biome ci resources/js/ templates/ parts/"
  },
  "dependencies": {
    "@alpinejs/collapse": "^3.15.11",
    "@alpinejs/focus": "^3.15.11",
    "alpinejs": "^3.15.11",
    "gsap": "^3.14.2",
    "swiper": "^12.1.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.10",
    "@roots/vite-plugin": "^2.0.2",
    "@tailwindcss/vite": "^4.2.2",
    "laravel-vite-plugin": "^3.0.1",
    "tailwindcss": "^4.2.2",
    "vite": "^8.0.3"
  }
}
